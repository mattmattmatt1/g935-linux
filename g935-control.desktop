[Desktop Entry]
Type=Application
Name=G935 Control
Comment=Sidetone, EQ and lighting control for the Logitech G935
# After `./install.sh --user` the wrapper is on PATH as `g935-control`.
Exec=g935-control
Icon=audio-headset
Terminal=false
Categories=AudioVideo;Audio;Settings;
StartupNotify=false
StartupWMClass=g935-control
